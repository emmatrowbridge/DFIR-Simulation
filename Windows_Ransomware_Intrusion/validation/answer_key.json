{
  "case_name": "Windows Ransomware Intrusion",

  "required_fields": [
    "q1_account_name",
    "q2_logon_type",
    "q3_first_logon_timestamp",
    "q4_logon_id",
    "q5_session_artifact",
    "q6_session_origin",

    "q7_suspicious_executable",
    "q8_execution_artifact",
    "q9_executable_path",
    "q10_execution_count",
    "q11_last_execution_timestamp",
    "q12_additional_executable",

    "q13_modified_file_extension",
    "q14_example_modified_files",
    "q15_affected_directories",
    "q16_scope_assessment",
    "q17_unaffected_file",

    "q18_ransom_note_filename",
    "q19_ransom_note_quote",
    "q20_recovery_statement",
    "q21_ransom_note_warnings",

    "q22_sequence_of_events",
    "q23_initial_access_evidence",
    "q24_execution_evidence",
    "q25_multi_system_impact_evidence",

    "q26_overall_impact",
    "q27_affected_file_types",
    "q28_additional_impact_evidence"
  ],

  "validators": {
    "q1_account_name": {
      "type": "exact_string",
      "expected": "ITAdmin"
    },

    "q2_logon_type": {
      "type": "keyword_list",
      "keywords": ["3", "network", "10", "remoteinteractive"]
    },

    "q3_first_logon_timestamp": {
      "type": "exact_string",
      "expected": "2026-04-24 18:38"
    },

    "q4_logon_id": {
      "type": "exact_string",
      "expected": "0x9C0EC0"
    },

    "q5_session_artifact": {
      "type": "keyword_list",
      "keywords": ["terminalservices", "localsessionmanager"]
    },

    "q6_session_origin": {
      "type": "keyword_text",
      "required_groups": {
        "remote": ["remote", "network"],
        "evidence": ["logon type", "terminalservices"]
      }
    },

    "q7_suspicious_executable": {
      "type": "keyword_list",
      "keywords": ["python.exe", "python"]
    },

    "q8_execution_artifact": {
      "type": "keyword_list",
      "keywords": ["prefetch"]
    },

    "q9_executable_path": {
      "type": "keyword_list",
      "keywords": ["python"]
    },

    "q10_execution_count": {
      "type": "keyword_list",
      "keywords": ["2", "3", "4", "5"]
    },

    "q11_last_execution_timestamp": {
      "type": "keyword_list",
      "keywords": ["2026", "04"]
    },

    "q12_additional_executable": {
      "type": "keyword_list",
      "keywords": ["nano.exe", "nano"]
    },

    "q13_modified_file_extension": {
      "type": "exact_string",
      "expected": ".locked"
    },

    "q14_example_modified_files": {
      "type": "exact_set",
      "expected": [
        "client_call_agenda.txt.locked",
        "april_expenses.csv.locked",
        "vendor_payments.csv.locked",
        "site_671.jpg.locked"
      ]
    },

    "q15_affected_directories": {
      "type": "keyword_list",
      "keywords": ["documents", "finance", "vendors", "operations"]
    },

    "q16_scope_assessment": {
      "type": "keyword_text",
      "required_groups": {
        "spread": ["multiple", "many", "widespread"],
        "evidence": ["directories", "files"]
      }
    },

    "q17_unaffected_file": {
      "type": "keyword_list",
      "keywords": ["lol.txt"]
    },

    "q18_ransom_note_filename": {
      "type": "exact_string",
      "expected": "lol.txt"
    },

    "q19_ransom_note_quote": {
      "type": "keyword_list",
      "keywords": ["encrypted", "system is no longer operational"]
    },

    "q20_recovery_statement": {
      "type": "keyword_text",
      "required_groups": {
        "no_recovery": ["not possible", "cannot recover", "no longer accessible"]
      }
    },

    "q21_ransom_note_warnings": {
      "type": "keyword_text",
      "required_groups": {
        "warning1": ["do not attempt"],
        "warning2": ["do not modify", "further activity"]
      }
    },

    "q22_sequence_of_events": {
      "type": "keyword_text",
      "required_groups": {
        "access": ["logon", "access"],
        "execution": ["python", "execution"],
        "impact": ["encrypted", "locked"],
        "note": ["message", "note"]
      }
    },

    "q23_initial_access_evidence": {
      "type": "keyword_text",
      "required_groups": {
        "logon": ["4624", "logon"],
        "account": ["itadmin"]
      }
    },

    "q24_execution_evidence": {
      "type": "keyword_text",
      "required_groups": {
        "prefetch": ["prefetch"],
        "program": ["python"]
      }
    },

    "q25_multi_system_impact_evidence": {
      "type": "keyword_text",
      "required_groups": {
        "spread": ["multiple", "across"],
        "files": ["directories", "files"]
      }
    },

    "q26_overall_impact": {
      "type": "keyword_list",
      "keywords": ["widespread", "multiple", "system-wide"]
    },

    "q27_affected_file_types": {
      "type": "exact_set",
      "expected": [".txt", ".csv", ".jpg"]
    },

    "q28_additional_impact_evidence": {
      "type": "keyword_text",
      "required_groups": {
        "others": ["other users", "multiple systems", "similar problems"]
      }
    }
  }
}
