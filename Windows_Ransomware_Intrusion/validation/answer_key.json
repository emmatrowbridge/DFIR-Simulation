    },

    "q15_affected_directories": {
      "type": "allowed_subset",
      "min_count": 3,
      "allowed": [
        "~/Users/mtann/Desktop",
        "~/Users/mtann/Documents",
        "~/Users/mtann/Downloads",
        "~/Users/mtann/Pictures",
        "~/Users/mtann/Stark_Engineering/Archive",
        "~/Users/mtann/Stark_Engineering/Finance",
        "~/Users/mtann/Stark_Engineering/Operations",
        "~/Users/mtann/Stark_Engineering/Projects/Bridge_Inspection_Program",
        "~/Users/mtann/Stark_Engineering/Projects/City_Contracts",
        "~/Users/mtann/Stark_Engineering/Projects/Q2_Proposals",
