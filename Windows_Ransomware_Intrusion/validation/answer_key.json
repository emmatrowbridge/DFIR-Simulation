{
  "case_name": "Windows Ransomware Intrusion",

  "required_fields": [
    "q1_account_name",
    "q2_logon_type",
    "q3_first_logon_timestamp",
    "q4_logon_id",
    "q5_session_artifact",
    "q6_session_origin",

    "q7_suspicious_executable",
    "q8_execution_artifact",
    "q9_executable_path",
    "q10_execution_count",
    "q11_last_execution_timestamp",
    "q12_additional_executable",

    "q13_modified_file_extension",
    "q14_example_modified_files",
    "q15_affected_directories",
    "q16_scope_assessment",
    "q17_unaffected_file",

    "q18_ransom_note_filename",
    "q19_ransom_note_quote",
    "q20_recovery_statement",
    "q21_ransom_note_warnings",

    "q22_sequence_of_events",
    "q23_initial_access_evidence",
    "q24_execution_evidence",
    "q25_multi_system_impact_evidence",

    "q26_overall_impact",
    "q27_affected_file_types",
    "q28_additional_impact_evidence"
  ],

  "validators": {
    "q1_account_name": {
      "type": "exact_string",
      "expected": "ITAdmin"
    },

    "q2_logon_type": {
      "type": "keyword_text",
      "required_groups": {
        "type": ["10", "remoteinteractive", "remote interactive"]
      }
    },

    "q3_first_logon_timestamp": {
      "type": "keyword_text",
      "required_groups": {
        "date": ["2026-04-24", "4/24/2026", "04/24/2026"],
        "time": ["18:38", "6:38"]
      }
    },

    "q4_logon_id": {
      "type": "keyword_list",
      "keywords": ["0x9CA21A", "0x9CA1C2"]
    },

    "q5_session_artifact": {
      "type": "keyword_text",
      "required_groups": {
        "provider": ["terminalservices", "terminal services"],
        "channel": ["localsessionmanager", "local session manager"]
      }
    },

    "q6_session_origin": {
      "type": "keyword_text",
      "required_groups": {
        "origin": ["remote", "rdp", "remote desktop"],
        "source": ["192.168.19.1"],
        "artifact": ["terminalservices", "terminal services", "logon type 10"]
      }
    },

    "q7_suspicious_executable": {
      "type": "exact_string",
      "expected": "PYTHON.EXE"
    },

    "q8_execution_artifact": {
      "type": "keyword_text",
      "required_groups": {
        "artifact": ["prefetch"],
        "file": ["PYTHON.EXE-E2B2C5E6", "python.exe-e2b2c5e6"]
      }
    },

    "q9_executable_path": {
      "type": "keyword_text",
      "required_groups": {
        "user": ["ITADMIN"],
        "python_dir": ["PYTHON313"],
        "executable": ["PYTHON.EXE"]
      }
    },

    "q10_execution_count": {
      "type": "exact_string",
      "expected": "7"
    },

    "q11_last_execution_timestamp": {
      "type": "keyword_text",
      "required_groups": {
        "date": ["2026-04-24", "4/24/2026", "04/24/2026"],
        "time": ["18:34:09", "6:34:09"]
      }
    },

    "q12_additional_executable": {
      "type": "exact_string",
      "expected": "NANO.EXE"
    },

    "q13_modified_file_extension": {
      "type": "exact_string",
      "expected": ".locked"
    },

    "q14_example_modified_files": {
      "type": "allowed_subset",
      "min_count": 4,
      "allowed": [
        "field_team_assignments.csv.locked",
        "closed_contracts.txt.locked",
        "old_projects.txt.locked",
        "contract_notes.txt.locked",
        "permit_deadlines.txt.locked",
        "client_call_agenda.txt.locked",
