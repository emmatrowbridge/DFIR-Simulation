    "q16_scope_assessment": {
      "type": "keyword_text",
      "required_groups": {
        "scope": ["widespread", "broad", "multiple directories", "across multiple"],
        "evidence1": ["desktop", "documents", "downloads", "pictures", "stark_engineering"],
        "evidence2": ["locked", ".locked"]
      }
    },

    "q17_unaffected_file": {
      "type": "keyword_list",
      "keywords": [
        "risk_notes.txt",
        "closed_contracts.txt",
        "old_projects.txt",
        "Book.xlsx",
        "april_expenses.csv",
        "lol.txt",
        "PBTG-Bridge-Barron-County-WI-e1712253655978.webp",
        "client_list.csv",
        "proposal_outline.txt",
        "environmental_notes.txt",
        "site_visit_log.txt",
        "contract_status.txt",
        "vendor_contacts.csv.txt",
        "budget_estimate.csv",
        "draft_summary.txt",
        "stakeholder_notes.txt"
      ]
    },

    "q18_ransom_note_filename": {
      "type": "exact_string",
      "expected": "lol.txt"
    },

    "q19_ransom_note_quote": {
      "type": "keyword_list",
      "keywords": [
        "Your files have been encrypted",
        "This system is no longer operational",
        "Data across this device has been locked",
        "Do not attempt to recover files",
        "Do not modify anything on this system",
        "You will not restore access on your own"
      ]
    },

    "q20_recovery_statement": {
      "type": "keyword_text",
      "required_groups": {
        "recovery": ["will not restore", "not restore", "no longer accessible", "locked", "encrypted"],
        "meaning": ["cannot", "not", "restricted", "no access"]
      }
    },

    "q21_ransom_note_warnings": {
      "type": "keyword_text",
      "required_groups": {
        "recover": ["do not attempt to recover", "do not attempt"],
        "modify": ["do not modify", "modify anything"],
        "worse": ["further activity", "make things worse"]
      }
    },

    "q22_sequence_of_events": {
      "type": "keyword_text",
      "required_groups": {
        "normal_user": ["mtann", "madison", "local"],
        "remote_access": ["ITAdmin", "remote", "192.168.19.1"],
        "execution": ["python", "PYTHON.EXE", "prefetch"],
        "encryption": ["locked", ".locked", "encrypted"],
        "note": ["lol.txt", "ransom note", "message"]
      }
    },

    "q23_initial_access_evidence": {
      "type": "keyword_text",
      "required_groups": {
        "security": ["Security", "4624"],
        "account": ["ITAdmin"],
        "remote": ["logon type 10", "RemoteInteractive", "192.168.19.1"]
      }
    },

    "q24_execution_evidence": {
      "type": "keyword_text",
      "required_groups": {
        "prefetch": ["prefetch", "PYTHON.EXE-E2B2C5E6"],
        "program": ["PYTHON.EXE", "python"],
        "count_or_time": ["7", "18:34", "2026-04-24"]
      }
    },

    "q25_multi_system_impact_evidence": {
      "type": "keyword_text",
      "required_groups": {
        "spread": ["multiple", "across", "many"],
        "locations": ["directories", "folders"],
        "locked": ["locked", ".locked"]
      }
    },

    "q26_overall_impact": {
      "type": "keyword_text",
      "required_groups": {
        "scope": ["widespread", "broad", "many", "multiple"],
        "impact": ["encrypted", "locked", "modified"],
        "location": ["directories", "folders", "system"]
      }
    },

    "q27_affected_file_types": {
      "type": "allowed_subset",
      "min_count": 3,
      "allowed": [
        ".txt",
        ".csv",
        ".jpg",
        ".png",
        ".pdf",
        ".xlsx",
        ".zip",
        ".webp"
      ]
    },

    "q28_additional_impact_evidence": {
      "type": "keyword_text",
      "required_groups": {
        "case_scope": ["other users", "additional users", "similar problems"],
        "impact": ["reported", "affected", "problems"]
      }
    }
  }
}
